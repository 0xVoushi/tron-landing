{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(node:*)",
      "Bash(node -e:*)",
      "Bash(npm run:*)",
      "Bash(npm list:*)",
      "Bash(npx next:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx playwright:*)",
      "Bash(npx vitest:*)",
      "Bash(python3:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(curl:*)",
      "Bash(lsof -ti:3000)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:schema.org)",
      "WebFetch(domain:search.google.com)",
      "WebFetch(domain:docs.google.com)",
      "WebFetch(domain:skills.sh)",
      "WebFetch(domain:pageflows.com)",
      "WebFetch(domain:morningtick.com)",
      "WebFetch(domain:www.saasui.design)",
      "Read(//tmp/**)",
      "mcp__ide__getDiagnostics",
      "Bash(npx create-next-app@latest . --typescript --tailwind --app --src=false --eslint --no-import-alias --use-npm)",
      "Bash(yes \"\")",
      "WebFetch(domain:gokite.ai)",
      "mcp__MCP_DOCKER__fetch",
      "Bash(npm test:*)",
      "mcp__MCP_DOCKER__browser_take_screenshot",
      "mcp__MCP_DOCKER__browser_snapshot",
      "mcp__MCP_DOCKER__browser_evaluate",
      "mcp__MCP_DOCKER__browser_press_key",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__navigate_page",
      "Bash(npm install *)",
      "Bash(export PATH=\"/opt/homebrew/bin:$PATH\")",
      "Bash(npm --version)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "mcpServers": {
    "Figma": {
      "url": "http://127.0.0.1:3845/mcp"
    },
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run"
      ]
    },
    "chrome-devtools": {
      "command": "npx -y chrome-devtools-mcp@latest",
      "env": {},
      "args": []
    }
  }
}
